{
  "name": "openclaw-electron",
  "version": "1.0.0",
  "description": "OpenClaw Electron fork — pinned to openclaw@2026.4.5, builds Windows EXE",
  "private": true,
  "main": "dist/main/main.js",
  "author": "OpenClaw Fork",
  "license": "MIT",
  "scripts": {
    "postinstall": "node scripts/hoist-openclaw-ext-deps.mjs",
    "verify:pin": "node scripts/verify-pin.mjs",
    "pin:write": "node scripts/pin-version.mjs",
    "clone:upstream": "node scripts/clone-upstream.mjs",
    "sync:src": "node scripts/sync-src.mjs",
    "compare:upstream": "node scripts/compare-upstream.mjs",
    "build:ts": "tsc -p tsconfig.json",
    "build:ts:prod": "tsc -p tsconfig.json --sourceMap false",
    "build:ts:watch": "tsc -p tsconfig.json -w",
    "dev": "concurrently -k \"tsc -p tsconfig.json -w\" \"wait-on dist/main/main.js && electron .\"",
    "dist:installer": "npm run build:ts:prod && npm run dist:nsis",
    "dist:nsis": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis",
    "dist:portable": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win portable",
    "dist:all": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win",
    "layer:pack-openclaw": "node scripts/pack-layer-openclaw.mjs",
    "layer:pack-root": "node scripts/pack-layer-root-runtime.mjs",
    "layer:pack-root:bump": "node scripts/pack-layer-root-runtime.mjs --bump",
    "layer:check": "node scripts/check-layer-overlap.mjs",
    "layer:manifest": "node scripts/generate-backend-manifest.mjs",
    "layer:smoke": "node scripts/smoke-test-layers.mjs",
    "layer:all": "npm run layer:check && npm run layer:pack-root && npm run layer:pack-openclaw && npm run layer:manifest && npm run layer:smoke"
  },
