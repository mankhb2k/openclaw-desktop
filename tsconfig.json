{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node16",
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": "app",
    "declaration": false,
    "sourceMap": true
  },
  "include": ["app/**/*.ts"]
}
